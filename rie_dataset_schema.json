{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qvox.local/schemas/rie-dataset-1.1.json",
  "title": "RI&E-dataset (Toverspreuk-datamodel) v1.1",
  "description": "Beslissingen 26 (BRF-categorie), 27 (Kinney E/B/W/R), 29 (toetsbrief scope-matrix) verwerkt. Foto-velden conform nieuwe spec: omschrijving + context.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bedrijf",
    "managementsamenvatting",
    "aanpak",
    "modules",
    "planVanAanpak",
    "functieRIE",
    "fotos",
    "toetsbrief"
  ],
  "properties": {
    "bedrijf": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "naam", "adres", "hoofdactiviteit", "medewerkers", "preventiemedewerker",
        "arbodienst", "bhv", "cao", "certificeringen", "vestigingen",
        "datumRIE", "vorigeRIE", "opgesteldDoor", "toetscertificaat"
      ],
      "properties": {
        "naam":               { "type": "string", "minLength": 1 },
        "adres":              { "type": "string" },
        "hoofdactiviteit":    { "type": "string" },
        "medewerkers":        { "type": "string", "description": "Exact getal met verdeling. Wordt overal consistent hergebruikt (voorblad, samenvatting, intro's)." },
        "preventiemedewerker":{ "type": "string" },
        "arbodienst":         { "type": "string" },
        "bhv":                { "type": "string" },
        "cao":                { "type": "string" },
        "certificeringen":    { "type": "string" },
        "vestigingen":        { "type": "string" },
        "datumRIE":           { "type": "string" },
        "vorigeRIE":          { "type": "string" },
        "opgesteldDoor":      { "type": "string" },
        "toetscertificaat":   { "type": "string" }
      }
    },

    "managementsamenvatting": {
      "type": "object",
      "additionalProperties": true,
      "required": ["intro", "watGoed", "verbeterpunten"],
      "properties": {
        "intro":          { "type": "string", "minLength": 1 },
        "watGoed":        { "type": "string" },
        "verbeterpunten": { "type": "string" }
      }
    },

    "aanpak": {
      "type": "object",
      "additionalProperties": true,
      "required": ["toelichting", "methode", "proportionaliteit"],
      "properties": {
        "toelichting":       { "type": "string" },
        "methode":           { "type": "string" },
        "proportionaliteit": { "type": "string" }
      }
    },

    "acuteRisicos": {
      "type": "array",
      "description": "Acute risico's volgen een eigen spoor buiten Kinney. Structuur nog te formaliseren zodra een eerste geval zich voordoet.",
      "items": { "type": "object", "additionalProperties": true }
    },

    "modules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/module" }
    },

    "planVanAanpak": {
      "type": "array",
      "items": { "$ref": "#/$defs/pvaActie" }
    },

    "functieRIE": {
      "type": "array",
      "items": { "$ref": "#/$defs/functie" }
    },

    "fotos": {
      "type": "array",
      "items": { "$ref": "#/$defs/foto" }
    },

    "toetsbrief": {
      "$ref": "#/$defs/toetsbrief"
    }
  },

  "$defs": {

    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "titel", "intro", "vragen"],
      "properties": {
        "code":  {
          "type": "string",
          "pattern": "^[FLOP][0-9]+$"
        },
        "titel": { "type": "string", "minLength": 1 },
        "intro": {
          "type": "string",
          "description": "Bedrijfsspecifieke intro. Is data, niet sjabloontekst (Beslissing 23)."
        },
        "vragen": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/vraag" }
        }
      }
    },

    "vraag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nr", "vraag", "antwoord", "bevinding"],
      "properties": {
        "nr": {
          "type": "string",
          "pattern": "^[FLOP][0-9]+-[0-9]+$"
        },
        "vraag":    { "type": "string", "minLength": 1 },
        "antwoord": {
          "enum": ["Ja", "Nee", "NVT", "Gericht uit te vragen"]
        },
        "bevinding": { "type": "string" },
        "brf":       { "type": "string", "description": "Korte beschrijvende tekst van het risico." },
        "brf_categorie": {
          "enum": ["Inrichting arbeidsplaats", "Arbeidsmiddel", "Kennis ontbreekt", "Gedrag", "Werkorganisatie", ""],
          "description": "Vaste vijfpuntsset (Beslissing 26). Verplicht bij Nee."
        },
        "kinney": { "$ref": "#/$defs/kinney" },
        "klasse": {
          "enum": ["Laag", "Middel", "Hoog", ""],
          "description": "Berekend uit Kinney R en dodelijk-regel (Beslissing 27). Nooit handmatig invullen."
        },
        "pva": {
          "type": "string",
          "description": "Verwijzing naar actienummer in planVanAanpak."
        }
      },
      "allOf": [
        {
          "if":   { "properties": { "antwoord": { "const": "Nee" } }, "required": ["antwoord"] },
          "then": {
            "required": ["brf", "brf_categorie", "kinney", "klasse", "pva", "bevinding"],
            "properties": {
              "brf":           { "type": "string", "minLength": 1 },
              "brf_categorie": { "enum": ["Inrichting arbeidsplaats", "Arbeidsmiddel", "Kennis ontbreekt", "Gedrag", "Werkorganisatie"] },
              "klasse":        { "enum": ["Laag", "Middel", "Hoog"] },
              "pva":           { "type": "string", "minLength": 1 }
            }
          }
        },
        {
          "if":   { "properties": { "antwoord": { "const": "NVT" } }, "required": ["antwoord"] },
          "then": {
            "required": ["bevinding"],
            "properties": { "bevinding": { "type": "string", "minLength": 1 } }
          }
        }
      ]
    },

    "kinney": {
      "type": "object",
      "description": "Risicoscore per Nee-bevinding (Beslissing 27). E vast per vraag (bibliotheek), B sectorstandaard (bijstelbaar), W beoordelaarsinvoer. R = E x B x W, berekend.",
      "additionalProperties": false,
      "required": ["E", "B", "W", "R"],
      "properties": {
        "E": {
          "type": "number",
          "enum": [1, 3, 7, 15, 40],
          "description": "Ernst: 1=gering / 3=belangrijk / 7=ernstig / 15=zeer ernstig / 40=dodelijk/ramp."
        },
        "B": {
          "type": "number",
          "enum": [0.5, 1, 2, 3, 6, 10],
          "description": "Blootstelling: 0.5=zeer zelden / 1=jaarlijks / 2=maandelijks / 3=wekelijks / 6=dagelijks / 10=continu."
        },
        "W": {
          "type": "number",
          "enum": [0.1, 0.5, 1, 3, 6, 10],
          "description": "Waarschijnlijkheid: beoordelaarsinvoer. 0.1=vrijwel onmogelijk ... 10=te verwachten."
        },
        "R": {
          "type": "number",
          "description": "R = E x B x W. Berekend, nooit handmatig. Klasse-grenzen: R<20 Laag, 20<=R<70 Middel, R>=70 Hoog. Dodelijk-regel: E>=40 geeft minimaal Middel ongeacht R."
        }
      }
    },

    "pvaActie": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nr", "ref", "onderwerp", "maatregel", "tree", "prio", "termijn"],
      "properties": {
        "nr":        { "type": "string", "pattern": "^[0-9]+$" },
        "ref":       { "type": "string", "description": "Onderbouwende vraagnummers, bv. 'F1-1 / F1-2'." },
        "onderwerp": { "type": "string", "minLength": 1 },
        "maatregel": { "type": "string", "minLength": 1 },
        "tree":      { "type": "string", "minLength": 1, "description": "Arbeidshygiënische strategie: bron / technisch / organisatorisch / PBM." },
        "prio":      { "enum": ["Laag", "Middel", "Hoog"] },
        "termijn":   { "enum": ["Kort (binnen 3 maanden)", "Middellang (binnen 12 maanden)", "Wanneer redelijk (binnen 2 jaar)"] },
        "verantw":   { "type": "string" },
        "status":    { "type": "string" }
      }
    },

    "functie": {
      "type": "object",
      "additionalProperties": false,
      "required": ["functie", "omschrijving", "risicos"],
      "properties": {
        "functie":     { "type": "string", "minLength": 1 },
        "omschrijving":{ "type": "string" },
        "risicos": {
          "type": "array",
          "description": "Elk risico is een triplet [risico, maatregel, ref].",
          "items": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3
          }
        }
      }
    },

    "foto": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nr", "bestand", "locatie", "omschrijving", "context", "refs"],
      "properties": {
        "nr":          { "type": "integer", "minimum": 1 },
        "bestand":     { "type": "string", "minLength": 1 },
        "locatie":     { "type": "string" },
        "omschrijving":{ "type": "string", "description": "Neutraal beschrijven wat je ziet." },
        "context":     { "type": "string", "description": "Perspectief of context als dat de interpretatie beinvloedt, bv. 'van bovenaf gefotografeerd'. Mag leeg." },
        "refs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[FLOP][0-9]+-[0-9]+$" }
        }
      }
    },

    "toetsbrief": {
      "type": "object",
      "description": "Scope-tekst en scope-matrix (Beslissing 29). Scope-inleiding is vaste tekst; matrix bepaalt per onderdeel welke kerndeskundigheid van toepassing is.",
      "additionalProperties": false,
      "required": ["scope_inleiding", "scope_matrix"],
      "properties": {
        "scope_inleiding": {
          "type": "string",
          "minLength": 1,
          "description": "Vaste tekst conform Beslissing 29."
        },
        "scope_matrix": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["onderdeel", "ao", "ah", "hvk"],
            "properties": {
              "onderdeel": { "type": "string", "minLength": 1 },
              "ao":  { "type": "boolean" },
              "ah":  { "type": "boolean" },
              "hvk": { "type": "boolean" }
            }
          }
        }
      }
    }

  }
}
